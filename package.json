{
	"name": "agent-credit-protocol",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "pnpm test:solana",
		"test:solana": "cd solana && anchor test --skip-build --provider.cluster localnet --validator legacy",
		"build:web": "vite build --config web/vite.config.ts",
		"dev:web": "vite --config web/vite.config.ts",
		"sync:idl": "cp solana/target/idl/agc_solana.json web/src/agc/agc_solana.json && cp solana/target/types/agc_solana.ts web/src/agc/agc_solana.ts",
		"simulate:epochs": "python3 script/simulate_policy.py"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.95.2",
		"buffer": "^6.0.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@coral-xyz/anchor": "^0.32.1",
		"@solana/spl-token": "^0.4.14",
		"@solana/web3.js": "^1.98.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"mocha": "^11.7.5",
		"ts-mocha": "^11.1.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
